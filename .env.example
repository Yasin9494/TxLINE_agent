# Copy to .env and fill in. NEVER commit the real .env.

# TxLINE
TXLINE_BASE_URL=https://txline.txodds.com
# League id(s) to subscribe to. World Cup real-time = Level 12 (TBD exact value).
TXLINE_LEAGUES=
# Filled in automatically after activation; cache to avoid re-registering.
TXLINE_API_TOKEN=

# Solana
# Path to the wallet keypair JSON used for activation + anchoring (KEEP SECRET).
SOLANA_KEYPAIR_PATH=./.secrets/wallet.json
# devnet | mainnet-beta  (free World Cup activation tx is on mainnet)
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Telegram bot (from @BotFather). Leave blank to run the dashboard in dry-run.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
